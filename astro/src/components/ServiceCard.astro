---
export interface Props {
  icon: string;
  title: string;
  description: string;
  features?: string[];
  price: string;
  featured?: boolean;
  linkText?: string;
}

const { icon, title, description, features = [], price, featured = false, linkText = 'Demander →' } = Astro.props;
---

<div class={`service-card${featured ? ' featured' : ''}`}>
  <div class="service-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  {
    features.length > 0 && (
      <ul class="service-features">
        {features.map(f => <li>{f}</li>)}
      </ul>
    )
  }
  <div class="service-price"><slot name="price-extra" />{price}</div>
  <slot />
  <a href="#contact" class="service-link">{linkText}</a>
</div>
