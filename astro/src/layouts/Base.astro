---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: 'fr' | 'en';
  ogLocale?: string;
  ogUrl?: string;
  hreflangFr?: string;
  hreflangEn?: string;
}

const {
  title = 'INDXONE — Consultant SI &amp; Architecte Digital',
  description = 'Consultant SI / AMOA et cr\u00e9ateur d\'IndxOne Hub. Pilotage, automatisation, outils SaaS pour freelances IT et PME en transition digitale.',
  ogImage = 'https://indxone.com/img/icon-ix.png',
  lang = 'fr',
  ogLocale = 'fr_FR',
  ogUrl = 'https://indxone.com/',
  hreflangFr = 'https://indxone.com/',
  hreflangEn = 'https://indxone.com/en/',
} = Astro.props;

import '../styles/variables.css';
import '../styles/components.css';
import '../styles/main.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import NavEn from '../components/NavEn.astro';
import FooterEn from '../components/FooterEn.astro';

const isEn = lang === 'en';
const siteName = 'INDXONE';
const ogSiteName = siteName;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Koffi NIAMKEY - INDXONE" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={ogSiteName} />
  <meta property="og:locale" content={ogLocale} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="alternate" hreflang="fr" href={hreflangFr} />
  <link rel="alternate" hreflang="en" href={hreflangEn} />
  <link rel="alternate" hreflang="x-default" href={hreflangFr} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Sora:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />

  <link rel="preload" href="/css/main.css" as="style" />

  <noscript>
    <style>
      .reveal { opacity: 1 !important; transform: none !important; }
      .nav-links { display: none !important; }
    </style>
  </noscript>
</head>

<body>
  {isEn
    ? <a href="#main-content" class="skip-link">Skip to main content</a>
    : <a href="#main-content" class="skip-link">Aller au contenu principal</a>
  }
  {isEn ? <NavEn /> : <Nav />}
  <main id="main-content">
    <slot />
  </main>
  {isEn ? <FooterEn /> : <Footer />}

  <script defer data-domain="indxone.com" src="https://plausible.io/js/script.js"></script>
  <script src="/js/main.js" is:inline></script>
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (systemPrefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
<style is:global>
  .skip-link {
    position: absolute; top: -100%; left: 0; z-index: 10000;
    padding: 0.5rem 1rem; background: #0F1923; color: #fff;
    font-size: 0.875rem; font-weight: 600; text-decoration: none;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 0;
  }
</style>

</body>
</html>
