---
import Base from '../../layouts/Base.astro';
const title = 'INDXONE — Municipality Websites | Local Gov Offer';
const description = 'Your town\'s official website in 48h. Turnkey, GDPR native, Lighthouse 96+. From €890.';
---
<Base title={title} description={description} lang="en" ogLocale="en_US" ogUrl="https://indxone.com/en/collectivites" hreflangFr="https://indxone.com/collectivites" hreflangEn="https://indxone.com/en/collectivites">
  <section class="collectivites-hero" id="hero">
    <div class="collectivites-hero-badge">🏛️ Local Gov Offer · INDXONE</div>
    <h1>Your <em>municipality</em>'s official website, in 48h</h1>
    <p>A turnkey institutional website, GDPR compliant, accessible and performant. Designed for town halls without an IT department or web budget.</p>
    <div class="collectivites-hero-stats">
      <div class="ch-stat"><strong>48h</strong><span>Guaranteed deployment</span></div>
      <div class="ch-stat"><strong>96+</strong><span>Lighthouse score</span></div>
      <div class="ch-stat"><strong>€0</strong><span>Hosting included</span></div>
      <div class="ch-stat"><strong>0</strong><span>Third-party cookies · Native GDPR</span></div>
    </div>
    <div class="collectivites-hero-actions">
      <a href="#contact-cta" class="btn-primary">Request a free demo →</a>
      <a href="#tarifs" class="btn-ghost">See pricing</a>
    </div>
  </section>

  <div class="collectivites-demo-bar">
    <span class="cdb-badge">LIVE</span>
    <span class="cdb-url">mairies.indxone.com/mons-en-laonnois</span>
    <span class="cdb-meta">· Mons-en-Laonnois (02) · ~1,150 pop.</span>
  </div>

  <section class="collectivites-problem" id="pourquoi">
    <div class="section-label">The problem</div>
    <h2>Why municipalities need INDXONE</h2>
    <p class="section-sub">The majority of rural municipalities have no website — or have an outdated, slow, inaccessible one. No IT department, no budget, no local provider.</p>
    <div class="cp-grid">
      <div class="cp-card"><div class="cp-icon">🌐</div><div class="cp-stat">35,000</div><h3>Municipalities without a website</h3><p>Over half of French rural municipalities have no official digital presence.</p></div>
      <div class="cp-card"><div class="cp-icon">💸</div><div class="cp-stat">€3–15k</div><h3>Average web agency price</h3><p>Budget out of reach for small towns with decreasing allocations.</p></div>
      <div class="cp-card"><div class="cp-icon">⏱️</div><div class="cp-stat">3–6 months</div><h3>Traditional timelines</h3><p>From specs to launch. INDXONE delivers in 48 business hours.</p></div>
    </div>
  </section>

  <section class="collectivites-steps">
    <div class="section-label">How it works</div>
    <h2>Deployment in 5 steps</h2>
    <p class="section-sub">From first contact to launch — everything is managed by INDXONE.</p>
    <div class="cs-grid">
      <div class="cs-step"><div class="cs-num">1</div><h3>📞 Discovery call</h3><p>30 min to understand your needs and collect key info</p><div class="cs-day">D·0</div></div>
      <div class="cs-step"><div class="cs-num">2</div><h3>📋 Data collection</h3><p>Simplified form: hours, contacts, news, agenda</p><div class="cs-day">D·1</div></div>
      <div class="cs-step"><div class="cs-num">3</div><h3>⚙️ Configuration</h3><p>Full customization from a single config.js file</p><div class="cs-day">D·1–2</div></div>
      <div class="cs-step"><div class="cs-num">4</div><h3>🚀 Deployment</h3><p>Netlify go-live, DNS, automatic HTTPS</p><div class="cs-day">D·2</div></div>
      <div class="cs-step"><div class="cs-num">5</div><h3>🎓 Training</h3><p>1h video call to empower the secretariat for updates</p><div class="cs-day">D·3–5</div></div>
    </div>
  </section>

  <section class="collectivites-pricing" id="tarifs">
    <div class="section-label">Pricing</div>
    <h2>Plans &amp; Prices</h2>
    <p class="section-sub">Catalogue pricing for local government plans, visible and easy to compare by level of service.</p>

    <div class="cpricing-grid">
      <div class="pc">
        <div class="ph"><span class="pb gold">Showcase</span><div class="pn">Essential presence</div><div class="pd">For municipalities without a site. Mayor's decision, no council vote needed.</div></div>
        <div class="pp"><div class="pa"><strong>€890</strong><span>excl. tax · one-time</span></div><div class="ps">+ maintenance option <strong>€19/month</strong></div></div>
        <div class="pf"><ul>
          <li>1-page site (hero, services, map, contact)</li>
          <li>Full customization</li>
          <li>Contact form</li>
          <li>Interactive OpenStreetMap</li>
          <li>Installable PWA</li>
          <li>Free Netlify hosting</li>
          <li>Source code delivered</li>
          <li>Native GDPR · Target 96+ Lighthouse</li>
        </ul></div>
        <a href="#contact-cta" class="pcta s">Choose Showcase →</a>
      </div>

      <div class="pc feat">
        <div class="ph"><span class="pb blue">⭐ Most popular</span><div class="pn">Active Commune</div><div class="pd">Full site with dynamic content and citizen alerts.</div></div>
        <div class="pp"><div class="pa"><strong>€1,490</strong><span>excl. tax · one-time</span></div><div class="ps">Separate maintenance <strong>from €29/month</strong></div></div>
        <div class="pf"><ul>
          <li>Everything in Showcase</li>
          <li>Rich agenda (category filters)</li>
          <li>News with images</li>
          <li>Live content via Google Sheets/Excel/Airtable</li>
          <li>Brevo citizen alerts</li>
          <li>1h video secretariat training</li>
          <li>Priority email support</li>
        </ul></div>
        <a href="#contact-cta" class="pcta p">Choose Active Commune →</a>
      </div>

      <div class="pc">
        <div class="ph"><span class="pb green">✦ New</span><div class="pn">Connected Commune</div><div class="pd">GPS reporting, weather, rich agenda for active towns.</div></div>
        <div class="pp"><div class="pa"><strong>€2,490</strong><span>excl. tax · one-time</span></div><div class="ps">Separate maintenance <strong>from €49/month</strong></div></div>
        <div class="pf"><ul>
          <li>Everything in Active Commune</li>
          <li>GPS incident reporting</li>
          <li>Local weather widget</li>
          <li>Dedicated subpages (school, planning…)</li>
          <li>2h secretariat training</li>
          <li>Social media integration</li>
        </ul></div>
        <a href="#contact-cta" class="pcta p green">Choose Connected →</a>
      </div>

      <div class="pc">
        <div class="ph"><span class="pb dark">Premium</span><div class="pn">Premium Commune</div><div class="pd">Pro + 12 months Active maintenance included. Best value bundle.</div></div>
        <div class="pp">
          <div class="pa"><strong>€3,490</strong><span>excl. tax · one-time</span></div>
          <div class="ps green-text">✓ 12 mo Active maint. included <span class="muted">(value €588)</span></div>
        </div>
        <div class="pf"><ul>
          <li>Everything in Connected Commune</li>
          <li>12 months free Active maintenance</li>
          <li>Unlimited content updates</li>
          <li>Monthly performance report</li>
          <li>Annual audit</li>
          <li>Eligible for DETR funding</li>
        </ul></div>
        <a href="#contact-cta" class="pcta s">Choose Premium →</a>
      </div>

      <div class="pc epci">
        <div class="ph epci-ph">
          <span class="pb epci-badge">Custom</span>
          <div class="pn epci-pn">Intercommunality</div>
          <div class="pd epci-pd">Multi-town portal for CA, CDC and inter-municipal structures.</div>
        </div>
        <div class="pp epci-pp">
          <div class="pa"><strong class="gold-text">€3,500</strong><span class="muted-text">excl. tax</span></div>
          <div class="ps muted-text">+ <strong class="gold-text">€199/month</strong> excl. tax</div>
        </div>
        <div class="pf epci-pf"><ul>
          <li>Centralized multi-town portal</li>
          <li>Inter-municipal admin dashboard</li>
          <li>Individual sites per town</li>
          <li>Centralized news management</li>
          <li>Priority SLA · Dedicated support</li>
          <li>Eligible for DETR / DSIL</li>
        </ul></div>
        <a href="#contact-cta" class="pcta gold">Contact us →</a>
      </div>
    </div>

    <p class="sub-label">Maintenance (after creation) — monthly or yearly (2 months free) :</p>
    <div class="maint-grid">
      <div class="mc"><div class="mn">Essential · Showcase</div><div class="mp">€19<span class="mp-unit">/month</span></div><div class="ma">or €190/year — 2 months free</div><div class="md">Hosting MCO + 1 update/month on request</div></div>
      <div class="mc"><div class="mn">Light</div><div class="mp">€29<span class="mp-unit">/month</span></div><div class="ma">or €290/year — save €58</div><div class="md">Hosting + minor corrections</div></div>
      <div class="mc act"><div class="mn">Active ★</div><div class="mp">€49<span class="mp-unit">/month</span></div><div class="ma">or €490/year — save €98</div><div class="md">Content updates + alerts + email support</div></div>
      <div class="mc"><div class="mn">Premium</div><div class="mp">€79<span class="mp-unit">/month</span></div><div class="ma">or €790/year — save €158</div><div class="md">Active + evolutions + monthly report</div></div>
    </div>

    <p class="sub-label">Optional add-on modules :</p>
    <div class="mod-grid">
      <div class="mk"><div class="mkn">Documents space</div><div class="mkp">€150 <span class="muted-text">excl. tax</span></div><div class="mkd">Council minutes, PLU, downloadable forms</div></div>
      <div class="mk"><div class="mkn">Room booking</div><div class="mkp">€190 <span class="muted-text">excl. tax</span></div><div class="mkd">Hall, gite, sports field</div></div>
      <div class="mk"><div class="mkn">POI Map</div><div class="mkp">€120 <span class="muted-text">excl. tax</span></div><div class="mkd">Shops, bus stops, points of interest</div></div>
      <div class="mk"><div class="mkn">Roadworks &amp; projects</div><div class="mkp">€150 <span class="muted-text">excl. tax</span></div><div class="mkd">Map + status + dates — reduces calls</div></div>
    </div>

    <div class="pricing-note">
      All prices excl. tax · VAT applicable per local gov rules · Payment 50% order / 50% delivery<br>
      <a href="#detr">→ Your projects may qualify for DETR or DSIL funding — we help you prepare the application.</a>
    </div>
  </section>

  <section class="detr-section" id="detr">
    <div class="detr-banner">
      <div>
        <div class="detr-tag">💡 Public funding</div>
        <h3>Eligible for DETR &amp; DSIL — we prepare the application with you</h3>
        <p>Premium Commune and custom plans qualify for the Rural Territories Equipment Grant. INDXONE assists with the application — at no extra cost.</p>
      </div>
      <a href="#contact-cta" class="btn-primary">Learn more →</a>
    </div>
  </section>

  <section class="collectivites-refs" id="demo">
    <div class="section-label">References</div>
    <h2>Municipalities already equipped or in progress</h2>
    <p class="section-sub">Deployed or in pipeline in the Laon district — Aisne (02).</p>
    <div class="refs-grid">
      <a href="https://mairies.indxone.com/mons-en-laonnois" class="ref-card"><div class="ref-icon">🏛️</div><div><div class="ref-name">Mons-en-Laonnois</div><div class="ref-meta">Active/Connected Commune reference · 02000 · INSEE 02497</div></div><span class="ref-status live">Live</span></a>
      <div class="ref-card"><div class="ref-icon">🏛️</div><div><div class="ref-name">Molinchart</div><div class="ref-meta">02000 · INSEE 02489 · ~400 pop.</div></div><span class="ref-status demo">Demo generated</span></div>
      <a href="https://mairies.indxone.com" class="ref-card"><div class="ref-icon">🏛️</div><div><div class="ref-name">Your municipality</div><div class="ref-meta">Aisne (02) · Hauts-de-France</div></div><span class="ref-status live">Available →</span></a>
    </div>
  </section>

  <section class="collectivites-faq" id="faq">
    <div class="section-label">Frequently asked questions</div>
    <h2>What mayors ask us</h2>
    <div class="faq-list">
      <div class="faq-item open">
        <div class="faq-q" onclick="this.closest('.faq-item').classList.toggle('open')">Is a town council vote required?</div>
        <div class="faq-a">Yes, a simple mayoral decision is sufficient for the entry plan. For higher plans, a council deliberation is recommended. We can help prepare the document.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.closest('.faq-item').classList.toggle('open')">Will the site really be ready in 48h?</div>
        <div class="faq-a">Yes, provided you supply the necessary information quickly (contacts, hours, 1-3 news items, logo if available). The 48 business hour timeline is contractual.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.closest('.faq-item').classList.toggle('open')">Can we have our own domain name?</div>
        <div class="faq-a">Absolutely. Netlify can connect any domain (e.g., mairie-nomcommune.fr) for free. INDXONE handles the DNS configuration. Domain purchase (~€12/year) is the municipality's responsibility.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.closest('.faq-item').classList.toggle('open')">Are projects eligible for DETR funding?</div>
        <div class="faq-a">Yes. Premium Commune and custom plans qualify for DETR and DSIL funding. INDXONE assists with the application at no extra cost.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.closest('.faq-item').classList.toggle('open')">What does native GDPR mean?</div>
        <div class="faq-a">The site loads no third-party scripts. No cookie banner is needed. The only data collected is from the contact form — which significantly simplifies your GDPR obligations.</div>
      </div>
    </div>
  </section>

  <section class="collectivites-cta" id="contact-cta">
    <h2>Your municipality deserves a proper website</h2>
    <p>Personalized demo — free, no commitment, delivered in 24h with your real data.</p>
    <div class="cta-links">
      <a href="mailto:contact@indxone.com" class="btn-primary">📧 Request a demo by email</a>
      <a href="tel:+33775679067" class="btn-ghost">📞 +33 7 75 67 90 67</a>
    </div>
  </section>

  <section class="collectivites-contact-form" id="contact-form">
    <div class="section-label">Contact us</div>
    <h2>Tell us about your municipality</h2>
    <p class="section-sub">Fill in the form and we'll get back to you within 24 business hours with your personalized demo.</p>
    <form class="contact-form" name="contact-commune-en" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/en/merci">
      <input type="hidden" name="form-name" value="contact-commune-en">
      <input type="hidden" name="bot-field">
      <div class="form-row">
        <div class="form-group"><label>Full Name *</label><input type="text" name="name" placeholder="Jean Dupont" required></div>
        <div class="form-group"><label>Email *</label><input type="email" name="email" placeholder="jean.dupont@mairie.fr" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Phone</label><input type="tel" name="phone" placeholder="+33 3 XX XX XX XX"></div>
        <div class="form-group"><label>Municipality Name *</label><input type="text" name="commune" placeholder="Your town name" required></div>
      </div>
      <div class="form-group"><label>Message *</label><textarea name="message" placeholder="Tell us about your needs and which plan interests you..." required></textarea></div>
      <div class="form-check"><input type="checkbox" id="consent-commune-en" name="consent" required><label for="consent-commune-en">I agree to my data being used to process my request, in accordance with the <a href="/en/privacy-policy">privacy policy</a>.</label></div>
      <button type="submit" class="form-submit">Send my request</button>
      <div class="form-note">Response within 24 business hours · GDPR compliant · No commitment</div>
    </form>
  </section>
</Base>

<script>
  (function() {
    var items = document.querySelectorAll('.faq-item');
    items.forEach(function(item) {
      var q = item.querySelector('.faq-q');
      if (q) {
        q.addEventListener('click', function() {
          item.classList.toggle('open');
        });
      }
    });
  })();
</script>

<style is:global>
  .collectivites-hero {
    background: linear-gradient(135deg, #1B3A6B 0%, #0F2847 100%);
    color: white; padding: 6rem 5% 5rem; position: relative; overflow: hidden;
  }
  .collectivites-hero::before {
    content: ''; position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .collectivites-hero-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    background: rgba(201,168,76,.2); border: 1px solid rgba(201,168,76,.4);
    color: #E8D5A0; font-size: .75rem; font-weight: 600;
    padding: .3rem .8rem; border-radius: 20px; margin-bottom: 1.5rem;
    letter-spacing: .05em; text-transform: uppercase;
  }
  .collectivites-hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.15;
    margin-bottom: 1.2rem; max-width: 700px; color: white;
  }
  .collectivites-hero h1 em { color: #E8D5A0; font-style: italic; }
  .collectivites-hero p { font-size: 1.05rem; color: rgba(255,255,255,.75); max-width: 540px; margin-bottom: 2rem; }
  .collectivites-hero-stats { display: flex; gap: 2.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .ch-stat strong { display: block; font-size: 1.6rem; font-weight: 700; color: #E8D5A0; }
  .ch-stat span { font-size: .78rem; color: rgba(255,255,255,.55); }
  .collectivites-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .collectivites-demo-bar {
    background: white; border-bottom: 2px solid #C9A84C;
    padding: .8rem 5%; display: flex; align-items: center;
    gap: 1rem; font-size: .82rem;
  }
  .cdb-badge { background: #2A7A4B; color: white; padding: .2rem .6rem; border-radius: 4px; font-size: .72rem; font-weight: 600; }
  .cdb-url { color: #2D5A9E; font-weight: 500; }
  .cdb-meta { color: #6b7280; }

  .cp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; }
  .cp-card { padding: 2rem; border: 1px solid var(--border); border-radius: 12px; border-top: 3px solid #C9A84C; }
  .cp-icon { font-size: 1.8rem; margin-bottom: 1rem; }
  .cp-stat { font-size: 2rem; font-weight: 700; color: #1B3A6B; margin-bottom: .3rem; }
  .cp-card h3 { font-size: .95rem; font-weight: 600; margin-bottom: .5rem; }
  .cp-card p { font-size: .85rem; color: var(--ink-light); }

  .collectivites-steps { background: var(--bone); }
  .cs-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.5rem; margin-top: 3rem; position: relative; }
  .cs-grid::before { content: ''; position: absolute; top: 32px; left: 10%; right: 10%; height: 1px; background: linear-gradient(90deg, #C9A84C, var(--border)); }
  .cs-step { text-align: center; position: relative; }
  .cs-num { width: 48px; height: 48px; border-radius: 50%; background: #1B3A6B; color: white; font-weight: 700; font-size: 1rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; position: relative; z-index: 1; border: 3px solid var(--bone); }
  .cs-step h3 { font-size: .85rem; font-weight: 600; margin-bottom: .3rem; }
  .cs-step p { font-size: .78rem; color: var(--ink-light); }
  .cs-day { font-size: .7rem; color: #C9A84C; font-weight: 600; margin-top: .4rem; }

  .collectivites-pricing { background: var(--white); }
  .cpricing-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.2rem; margin-top: 3rem; }
  .pc { border: 1px solid var(--border); border-radius: 16px; overflow: hidden; transition: transform .2s, box-shadow .2s; background: var(--bone); }
  .pc:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(15,25,35,.1); }
  .pc.feat { border: 2px solid #1B3A6B; background: var(--white); transform: scale(1.02); box-shadow: 0 8px 32px rgba(27,58,107,.15); }
  .pc.feat:hover { transform: scale(1.02) translateY(-4px); }
  .ph { padding: 1.5rem 1.5rem 1rem; border-bottom: 1px solid var(--border); }
  .pb { display: inline-block; font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .2rem .6rem; border-radius: 4px; margin-bottom: .8rem; }
  .pb.gold { background: #E8D5A0; color: #7a5a00; }
  .pb.blue { background: #DBEAFE; color: #1B3A6B; }
  .pb.green { background: #D1FAE5; color: #2A7A4B; }
  .pb.dark { background: #0F1923; color: white; }
  .pn { font-size: 1rem; font-weight: 700; margin-bottom: .3rem; }
  .pd { font-size: .78rem; color: var(--ink-light); line-height: 1.4; }
  .pp { padding: 1.2rem 1.5rem; border-bottom: 1px solid var(--border); }
  .pa { display: flex; align-items: baseline; gap: .3rem; margin-bottom: .2rem; }
  .pa strong { font-size: 2rem; font-weight: 700; color: var(--ink); }
  .pa span { font-size: .8rem; color: var(--ink-light); }
  .ps { font-size: .75rem; color: var(--ink-light); margin-top: .25rem; }
  .ps strong { color: #1B3A6B; }
  .ps.green-text { color: #2A7A4B; font-weight: 600; }
  .ps.green-text .muted { color: var(--ink-light); font-weight: 400; }
  .pf { padding: 1.5rem; }
  .pf ul { list-style: none; }
  .pf li { font-size: .8rem; padding: .35rem 0; display: flex; gap: .5rem; align-items: flex-start; color: var(--ink-light); border-bottom: 1px solid rgba(0,0,0,.04); }
  .pf li:last-child { border-bottom: none; }
  .pf li::before { content: '✓'; color: #2A7A4B; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .pcta { margin: 0 1.5rem 1.5rem; display: block; text-align: center; padding: .75rem; border-radius: 8px; font-weight: 600; font-size: .85rem; text-decoration: none; transition: all .2s; }
  .pcta.p { background: #1B3A6B; color: white; }
  .pcta.p:hover { background: #2D5A9E; }
