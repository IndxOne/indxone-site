---
import Base from '../../layouts/Base.astro';
const title = 'Legal Notice | INDXONE';
const description = 'Legal notice of INDXONE SASU — IT consulting firm, publisher of indxone.com and the municipal website offer.';
---
<Base title={title} description={description} lang="en" ogLocale="en_US" ogUrl="https://indxone.com/en/legal-notice" hreflangFr="https://indxone.com/mentions-legales" hreflangEn="https://indxone.com/en/legal-notice">
  <div class="container" style="padding:4rem 5%;max-width:800px">
    <header style="margin-bottom:3rem">
      <p class="section-label">Legal information</p>
