---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';

const title = 'INDXONE — Consultant SI & Architecte Digital';
const description = 'Consultant SI / AMOA Freelance et créateur d\'IndxOne Hub. Pilotage, automatisation, outils SaaS pour freelances IT et PME en transition digitale.';
---

<Base title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="hero-status">Disponible</div>
    <div class="hero-sub">Consultant SI Freelance · Paris & Remote</div>
    <h1>Architecte SI pour PME en <em>transition digitale</em></h1>
    <p>Je transforme vos processus métier en systèmes d'information robustes et automatisés. De la stratégie SI à l'exécution terrain.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">Démarrer un projet</a>
      <a href="#projets" class="btn-ghost">Voir les réalisations →</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><strong>8+</strong><span>Projets SI livrés</span></div>
      <div class="hero-stat"><strong>4 ans</strong><span>Pilotage IT</span></div>
      <div class="hero-stat"><strong>490€</strong><span>TJM HT</span></div>
      <div class="hero-stat"><strong>PME</strong><span>Industrielles</span></div>
    </div>
    <div class="dispo-card">
      <div class="dispo-item"><div class="label">Statut</div><div class="value green">● Disponible</div></div>
      <div class="dispo-item"><div class="label">Localisation</div><div class="value">Aisne · Paris · Remote</div></div>
      <div class="dispo-item"><div class="label">TJM affiché</div><div class="value gold">490 € HT</div></div>
      <div class="dispo-item"><div class="label">Démarrage</div><div class="value">Immédiat</div></div>
      <div class="dispo-item"><div class="label">Contrat</div><div class="value">Régie · Forfait</div></div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="section-label">Ce que je fais</div>
    <h2>Offres & Services</h2>
    <p class="section-sub">Des missions courtes à l'accompagnement long terme — calibrées selon votre maturité digitale.</p>
    <div class="services-grid">
      <ServiceCard 
        icon="🗺️" 
        title="Architecte SI & AMOA" 
        description="Cadrage, pilotage et gouvernance de vos projets de transformation SI. Du schéma directeur à la mise en production." 
        features={["Diagnostic & cartographie SI", "Cahier des charges fonctionnel", "Coordination prestataires (RACI)", "Gestion risques & planning"]} 
        price="Dès 4 jours · <strong>TJM sur devis</strong>"
      />
      <ServiceCard 
        icon="⚡" 
        title="Automatisation & No-code" 
        description="Supprimez les tâches répétitives. Je connecte vos outils et automatise vos workflows métier sans développement lourd." 
        features={["Power Automate / Power Apps", "Make · Zapier · n8n", "Intégrations API & webhooks", "Tableaux de bord Power BI"]} 
        price="Audit processus dès <strong>1 500 €</strong>"
      />
      <ServiceCard 
        icon="🏗️" 
        title="Infrastructure & Cloud" 
        description="MCO, migration cloud, sécurisation et administration de votre environnement IT. On-premise ou hybride." 
        features={["Azure / AWS / GCP", "Hyper-V · Entra ID · M365", "Téléphonie IP Teams", "CI/CD GitLab"]} 
        price="Audit infra dès <strong>990 €</strong>"
      />
      <ServiceCard 
        featured 
        icon="🚀" 
        title="Startup Launch Kit" 
        description="De l'idée au premier utilisateur en 8 semaines. Je structure, outille et pilote votre MVP pour lancer vite, sans dette technique. France & Afrique francophone." 
        price="Starter remboursable sur mission Launch"
      >
        <div class="kit-badge">★ Nouveau</div>
        <div class="kit-tiers">
          <div class="kit-tier">
            <div class="kit-tier-name">Starter</div>
            <div class="kit-tier-price">1 200 €</div>
            <div class="kit-tier-desc">Cadrage + roadmap + stack</div>
          </div>
          <div class="kit-tier">
            <div class="kit-tier-name">Launch</div>
            <div class="kit-tier-price">3 500 €</div>
            <div class="kit-tier-desc">Cadrage + outils + 8 semaines</div>
          </div>
          <div class="kit-tier">
            <div class="kit-tier-name">Full Pilot</div>
            <div class="kit-tier-price">Sur devis</div>
            <div class="kit-tier-desc">Go-live · TJM 580€</div>
          </div>
        </div>
        <a href="#contact" class="service-link" style="margin-top:1rem;">Réserver un call →</a>
      </ServiceCard>
    </div>
  </section>

  <!-- Collectivités Section -->
  <section class="collectivites-section" id="collectivites">
    <div class="section-label">Offre Collectivités</div>
    <div class="collectivites-inner">
      <div class="collectivites-preview">
        <div class="preview-bar">
          <div class="preview-dot" style="background:#FF5F57"></div>
          <div class="preview-dot" style="background:#FEBC2E; margin:0 4px;"></div>
          <div class="preview-dot" style="background:#28C840"></div>
          <div class="preview-url">mairies.indxone.com/mons-en-laonnois</div>
          <div class="preview-score">⚡ 96</div>
        </div>
        <div class="preview-body">
          <div class="preview-commune">Mairie de Mons-en-Laonnois</div>
          <div class="preview-meta">02000 · Code INSEE 02497 · ~1 150 hab.</div>
          <div class="preview-chips">
            <span class="preview-chip">✓ Site déployé · 48h</span>
            <span class="preview-chip">RGPD ready</span>
            <span class="preview-chip">0 cookie tiers</span>
          </div>
        </div>
      </div>
      <div class="collectivites-content">
        <h3>Sites web pour mairies & communes</h3>
        <p>Un site institutionnel clé en main, déployable en 48h, conforme RGPD et accessible. Conçu pour les communes sans DSI ni budget web.</p>
        <ul class="collectivites-features">
          <li>Design officiel adapté aux collectivités</li>
          <li>Carte interactive, formulaire, agenda</li>
          <li>Horaires d'ouverture dynamiques</li>
          <li>0 cookie tiers · RGPD ready · Lighthouse 96+</li>
          <li>Hébergement Netlify gratuit inclus</li>
          <li>Éligible financement DETR & DSIL</li>
        </ul>
        <div class="pricing-tiers-mini">
          <div class="tier-mini">
            <div class="tier-mini-name">Vitrine</div>
            <div class="tier-mini-price">490€ <small>HT · + 19€/mois opt.</small></div>
          </div>
          <div class="tier-mini highlighted">
            <div class="tier-mini-name">⭐ Commune Active</div>
            <div class="tier-mini-price">790€ <small>HT · unique</small></div>
          </div>
          <div class="tier-mini">
            <div class="tier-mini-name">Commune Connectée</div>
            <div class="tier-mini-price">1 090€ <small>HT · unique</small></div>
          </div>
          <div class="tier-mini">
            <div class="tier-mini-name">Premium</div>
            <div class="tier-mini-price">1 490€ <small>HT · 12 mois inclus</small></div>
          </div>
          <div class="tier-mini">
            <div class="tier-mini-name">EPCI</div>
            <div class="tier-mini-price">3 500€ <small>HT + 199€/mois</small></div>
          </div>
        </div>
        <div class="cta-group">
          <a href="/collectivites" class="btn-blue">Voir l'offre complète →</a>
          <a href="#contact" class="btn-outline">Demander une démo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Projets Section -->
  <section class="projets" id="projets">
    <div class="section-label">Réalisations</div>
    <h2>Projets Structurants</h2>
    <p class="section-sub">Menés en CDI et en freelance — en tant que pilote, référent ou AMOA.</p>

    <div class="projets-filters">
      <button class="pf-btn active" onclick="filterProjet(this,'all')">Tous les projets</button>
      <button class="pf-btn" onclick="filterProjet(this,'freelance')">⚡ IndxOne · Freelance</button>
      <button class="pf-btn" onclick="filterProjet(this,'cdi')">🏢 CDI · Référent IT</button>
    </div>

    <div class="bento">

      <div class="bento-card metric-card" data-type="freelance">
        <div>
          <span class="bc-tag freelance">⚡ IndxOne</span>
          <span class="bc-icon">🏛️</span>
          <div class="bc-title">Digitalisation communes</div>
          <div class="bc-desc" style="font-size:0.75rem;">Template institutionnel déployé · Aisne (02). Pipeline automatisé multi-communes en cours.</div>
          <div class="bc-chips"><span class="bc-chip">HTML/JS</span><span class="bc-chip">Netlify</span><span class="bc-chip">Python</span></div>
        </div>
        <div>
          <div class="bc-stats" style="margin-top:1.2rem;">
            <div class="bc-stat sm"><strong>48h</strong><span>Déploiement</span></div>
            <div class="bc-stat sm"><strong>96+</strong><span>Lighthouse</span></div>
          </div>
          <div class="bc-impact" style="margin-top:0.8rem;"><strong>Pipeline actif</strong>Mons-en-Laonnois · en expansion</div>
        </div>
        <div class="bc-number">IX</div>
      </div>

      <div class="bento-card mid-card" data-type="cdi">
        <span class="bc-tag cdi">CDI · Référent IT</span>
        <span class="bc-icon">📞</span>
        <div class="bc-title">Téléphonie IP — Microsoft Teams</div>
        <div class="bc-desc">Pilotage complet du déploiement Teams IP. Responsable & autorité projet de bout en bout.</div>
        <div class="bc-stats">
          <div class="bc-stat sm"><strong>110</strong><span>Collaborateurs</span></div>
          <div class="bc-stat sm"><strong>0</strong><span>Incident post-bascule</span></div>
        </div>
        <div class="bc-chips"><span class="bc-chip">Teams</span><span class="bc-chip">M365</span><span class="bc-chip">Pilotage</span></div>
      </div>

      <div class="bento-card mid-dark" data-type="cdi">
        <span class="bc-tag cdi">CDI · Référent IT</span>
        <span class="bc-icon">📊</span>
        <div class="bc-title">CRM Dynamics 365 + Power BI</div>
        <div class="bc-desc">Intégration Power BI dans Dynamics 365, évolution Power Apps. Reporting commercial temps réel.</div>
        <div class="bc-chips"><span class="bc-chip">Dynamics 365</span><span class="bc-chip">Power BI</span><span class="bc-chip">Power Apps</span></div>
      </div>

      <div class="bento-card wide-card" data-type="cdi">
        <span class="bc-tag cdi">CDI · Référent IT</span>
        <span class="bc-icon">⚙️</span>
        <div class="bc-title">Déploiement ERP DIAPASON</div>
        <div class="bc-desc">Coordination infra puis administration et configuration de l'ERP métier. Gestion des flux, droits utilisateurs et formation équipes.</div>
        <div class="bc-chips"><span class="bc-chip">ERP</span><span class="bc-chip">AMOA</span><span class="bc-chip">Formation</span><span class="bc-chip">Coordination</span></div>
      </div>

      <div class="bento-card wide-card" data-type="cdi">
        <span class="bc-tag cdi">CDI · Référent IT</span>
        <span class="bc-icon">🗂️</span>
        <div class="bc-title">GED & GTA Kelio</div>
        <div class="bc-desc">Mise en place de la gestion électronique documentaire et déploiement de la GTA Kelio sur l'ensemble du périmètre (~110 collaborateurs).</div>
        <div class="bc-chips"><span class="bc-chip">Kelio</span><span class="bc-chip">GED</span><span class="bc-chip">Formation</span></div>
      </div>

      <div class="bento-card full-card" data-type="cdi">
        <div class="full-card-left">
          <span class="bc-tag cdi">CDI · Référent IT</span>
          <span class="bc-icon">🧩</span>
          <div class="bc-title">Configurateur produit en ligne</div>
          <div class="bc-desc">Logique conditionnelle complexe pour un configurateur menuiserie temps réel. 117 niveaux, 815 questions, 908 réponses avec logique conditionnelle pour devis automatique et sortie CAM.</div>
          <div class="bc-chips"><span class="bc-chip">XML</span><span class="bc-chip">PHP</span><span class="bc-chip">Logique métier</span><span class="bc-chip">SQL</span></div>
        </div>
        <div class="full-card-right">
          <div class="full-stat-box"><strong>117</strong><span>Niveaux</span></div>
          <div class="full-stat-box"><strong>815</strong><span>Questions</span></div>
          <div class="full-stat-box"><strong>908</strong><span>Réponses</span></div>
        </div>
      </div>

    </div>
  </section>

  <!-- Tools / Hub Section -->
  <section class="tools-section" id="tools">
    <div class="section-label">Produit SaaS</div>
    <h2>IndxOne Hub</h2>
    <p class="section-sub">Un cockpit local-first pour freelances IT : vendre, cadrer, livrer, facturer et piloter sans empiler les plateformes.</p>
    <div class="hub-product">
      <div>
        <div class="kit-badge">Produit maintenu · Mai 2026</div>
        <h3>15 outils pour structurer une activité freelance IT.</h3>
        <p>Le Hub regroupe Missio, Deal Room, Runway, Daily Ops, Calc, SIPOC, MoSCoW, RACI, Devis, CRA et les outils financiers dans une expérience plus cohérente, avec thème global, retour Hub, démo Missio et changelog produit.</p>
        <div class="hub-badges">
          <span class="hub-badge">100% local par défaut</span>
          <span class="hub-badge">Démo Missio avant activation</span>
          <span class="hub-badge">Freemium clair</span>
        </div>
        <a href="https://hub.indxone.com" class="btn-primary" target="_blank" rel="noopener">Ouvrir le Hub →</a>
        <a href="https://hub.indxone.com/pourquoi.html" class="btn-outline" target="_blank" rel="noopener" style="margin-left:.6rem;">Pourquoi IndxOne</a>
      </div>
      <div class="hub-preview" aria-label="Aperçu IndxOne Hub">
        <div class="hub-preview-row"><span>Missio</span><strong>Pipeline + factures</strong></div>
        <div class="hub-preview-row"><span>Deal Room</span><strong>Vue client</strong></div>
        <div class="hub-preview-row"><span>Runway / Daily Ops</span><strong>Pilotage</strong></div>
        <div class="hub-preview-row"><span>Changelog</span><strong>Produit actif</strong></div>
      </div>
    </div>
    <div class="tools-grid">
      <div class="tool-card">
        <div class="tool-icon">💼</div>
        <h3>Missio</h3>
        <p>Pipeline, factures, TJM, revenu net et mode démo avant activation.</p>
        <a href="https://hub.indxone.com/missio-app.html" class="tool-link" target="_blank">Accéder à Missio →</a>
      </div>
      <div class="tool-card">
        <div class="tool-icon">◇</div>
        <h3>Deal Room</h3>
        <p>Vue client partageable : contexte, périmètre, livrables, risques et avancement.</p>
        <a href="https://hub.indxone.com/deal-room.html?v=2" class="tool-link" target="_blank">Créer une Deal Room →</a>
      </div>
      <div class="tool-card">
        <div class="tool-icon">🎯</div>
        <h3>Éval mission</h3>
        <p>Score Go/No-Go pondéré avant d'investir du temps commercial.</p>
        <a href="https://hub.indxone.com/eval-mission-v2.html" class="tool-link" target="_blank">Évaluer →</a>
      </div>
      <div class="tool-card">
        <div class="tool-icon">↗</div>
        <h3>Runway</h3>
        <p>Plan de charge 3 mois, viabilité, TJM cible et scénarios de revenu.</p>
        <a href="https://hub.indxone.com/runway.html" class="tool-link" target="_blank">Projeter →</a>
      </div>
      <div class="tool-card">
        <div class="tool-icon">✓</div>
        <h3>Daily Ops</h3>
        <p>Routine hebdo : relances, factures, pipeline, priorités et prochaines actions.</p>
        <a href="https://hub.indxone.com/daily-ops.html" class="tool-link" target="_blank">Piloter →</a>
      </div>
      <div class="tool-card">
        <div class="tool-icon">🧮</div>
        <h3>Calc</h3>
        <p>Scratchpad TJM, net mensuel et viabilité d'une mission en quelques minutes.</p>
        <a href="https://hub.indxone.com/calc-mission-simple.html" class="tool-link" target="_blank">Calculer →</a>
      </div>
    </div>
  </section>

  <!-- Stack Section -->
  <section class="stack" id="stack">
    <div class="section-label">Outillage</div>
    <h2>Environnement Technique</h2>
    <div class="stack-grid">
      <div class="stack-cat">
        <div class="stack-cat-name">Infra & Cloud</div>
        <div class="stack-items">
          <div class="stack-item">Azure / AWS / GCP</div>
          <div class="stack-item">Hyper-V · Entra ID</div>
          <div class="stack-item">Exchange · M365</div>
          <div class="stack-item">Téléphonie IP Teams</div>
        </div>
      </div>
      <div class="stack-cat">
        <div class="stack-cat-name">Data & Apps</div>
        <div class="stack-items">
          <div class="stack-item">Power BI</div>
          <div class="stack-item">Power Apps · Automate</div>
          <div class="stack-item">Dynamics 365</div>
          <div class="stack-item">DIAPASON ERP</div>
        </div>
      </div>
      <div class="stack-cat">
        <div class="stack-cat-name">No-code & Mobile</div>
        <div class="stack-items">
          <div class="stack-item">Make · Zapier · n8n</div>
          <div class="stack-item">FlutterFlow</div>
          <div class="stack-item">Airtable · Notion</div>
          <div class="stack-item">Tally · ClickUp</div>
        </div>
      </div>
      <div class="stack-cat">
        <div class="stack-cat-name">Méthodes & DevOps</div>
        <div class="stack-items">
          <div class="stack-item">Agile / Kanban / RACI</div>
          <div class="stack-item">GitLab CI/CD</div>
          <div class="stack-item">MoSCoW · SIPOC</div>
          <div class="stack-item">Supabase · Netlify</div>
        </div>
      </div>
    </div>
    <a href="https://www.malt.fr/profile/koffiniamkey2" class="malt-card" target="_blank">
      <div class="malt-logo">M</div>
      <div class="malt-info"><strong>Voir le profil Malt</strong><span>malt.fr · TJM 490 €</span></div>
      <div class="malt-arrow">→</div>
    </a>
  </section>

  <!-- Contact Section -->
  <section class="contact" id="contact">
    <div class="section-label">Parlons-nous</div>
    <div class="contact-grid">
      <div class="contact-info">
        <h3>Démarrons un projet ensemble</h3>
        <p>Un échange de 30 min suffit souvent pour clarifier les enjeux. Disponible immédiatement.</p>
        <div class="contact-links">
          <a href="tel:+33775679067" class="contact-link"><span class="icon">📞</span>07 75 67 90 67</a>
          <a href="mailto:contact@indxone.com" class="contact-link"><span class="icon">✉️</span>contact@indxone.com</a>
        </div>
        <div class="contact-platforms">
          <h4>Retrouvez-moi sur</h4>
          <div class="platform-links">
            <a href="https://www.malt.fr/profile/koffiniamkey2" class="platform-link" target="_blank">M Malt — TJM 490€ · Profil vérifié ↗</a>
            <a href="https://lehibou.com" class="platform-link" target="_blank">LH LeHibou — TJM 650€ · Consultant IT mission longue durée ↗</a>
            <a href="https://www.linkedin.com/in/koffi-niamkey/" class="platform-link" target="_blank">in LinkedIn — Koffi NIAMKEY · Page INDXONE ↗</a>
          </div>
        </div>
      </div>
      <form class="contact-form" name="contact-indxone" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/merci">
        <input type="hidden" name="form-name" value="contact-indxone" />
        <input type="hidden" name="bot-field" />
        <div class="form-row">
          <div class="form-group"><label>Nom *</label><input type="text" name="nom" placeholder="Dupont" required /></div>
          <div class="form-group"><label>Prénom</label><input type="text" name="prenom" placeholder="Jean" /></div>
        </div>
        <div class="form-group"><label>Email *</label><input type="email" name="email" placeholder="jean.dupont@entreprise.fr" required /></div>
        <div class="form-group">
          <label>Sujet *</label>
          <select name="sujet" required>
            <option value="">— Sélectionnez —</option>
            <option>Projet AMOA / Architecture SI</option>
            <option>Automatisation / No-code</option>
            <option>Infrastructure / Cloud</option>
            <option>Intégration ERP / CRM</option>
            <option>Startup Launch Kit</option>
            <option>IndxOne Hub / SaaS freelance</option>
            <option>Site mairie / Collectivité</option>
            <option>Autre demande</option>
          </select>
        </div>
        <div class="form-group"><label>Message *</label><textarea name="message" placeholder="Décrivez votre projet ou votre besoin..." required></textarea></div>
        <div class="form-check"><input type="checkbox" required /><span>J'accepte que mes données soient utilisées pour traiter ma demande.</span></div>
        <button type="submit" class="form-submit">Envoyer le message</button>
        <div class="form-note">Réponse sous 24h ouvrées · RGPD · Données non revendues</div>
      </form>
    </div>
  </section>
</Base>
