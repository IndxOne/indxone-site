---
import Base from '../layouts/Base.astro';
const title = 'Merci — INDXONE';
const description = 'Merci — Votre message a bien été reçu. Réponse sous 24h.';
---

<Base title={title} description={description}>
  <div class="card">
    <div class="check-wrap" aria-hidden="true">
      <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="36" cy="36" r="30" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
        <polyline points="22,36 32,46 50,28" stroke="#E8D5A0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>

    <h1>Message reçu <em>✓</em></h1>

    <p class="subtitle">
      Merci pour votre message.<br>
      Je vous réponds <strong>sous 24h ouvrées</strong> pour discuter de votre projet.
    </p>

    <h2 style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap">Détails de confirmation</h2>
    <div class="info-row">
      <div class="info-pill"><span class="dot"></span>Réponse par email</div>
      <div class="info-pill"><span class="dot"></span>24h ouvrées</div>
      <div class="info-pill"><span class="dot"></span>Sans engagement</div>
    </div>

    <a href="/" class="btn-back">← Retour à l'accueil</a>

    <div class="sec-links">
      <a href="/projets">Voir les réalisations</a>
      <a href="/collectivites">Offre collectivités</a>
      <a href="tel:+33775679067">07 75 67 90 67</a>
    </div>
  </div>
</Base>

<style is:global>
  body {
    background: linear-gradient(135deg, #0F1923 0%, #1B2D3E 100%);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--blue-mid));
    z-index: 10;
  }

  main {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 20px;
    padding: 3.5rem 3rem;
    max-width: 460px;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
    animation: fadeUp .6s ease both;
    backdrop-filter: blur(4px);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #C9A84C, var(--blue-mid));
    border-radius: 20px 20px 0 0;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .check-wrap {
    margin: 0 auto 2rem;
    width: 72px;
    height: 72px;
    animation: scaleIn .5s .2s ease both;
  }

  .check-wrap circle {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: circleDraw .6s .3s ease forwards;
  }

  .check-wrap polyline {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: checkDraw .4s .8s ease forwards;
  }

  @keyframes circleDraw {
    from { stroke-dashoffset: 200; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes checkDraw {
    from { stroke-dashoffset: 60; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes scaleIn {
    from { transform: scale(.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .card h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    color: #fff;
    margin-bottom: .8rem;
    animation: fadeUp .5s .4s ease both;
  }

  .card h1 em {
    color: #E8D5A0;
    font-style: italic;
  }

  .subtitle {
    color: rgba(255,255,255,.55);
    font-size: .88rem;
    line-height: 1.75;
    margin-bottom: 2rem;
    animation: fadeUp .5s .5s ease both;
  }

  .subtitle strong {
    color: #E8D5A0;
    font-weight: 600;
  }

  .info-row {
    display: flex;
    gap: .8rem;
    margin-bottom: 2rem;
    justify-content: center;
    animation: fadeUp .5s .55s ease both;
    flex-wrap: wrap;
  }

  .info-pill {
    display: flex;
    align-items: center;
    gap: .4rem;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px;
    padding: .5rem .9rem;
    font-size: .75rem;
    color: rgba(255,255,255,.6);
  }

  .info-pill .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C9A84C;
    flex-shrink: 0;
  }

  .btn-back {
    display: inline-block;
    background: #C9A84C;
    color: #0F1923;
    padding: .85rem 2rem;
    border-radius: 8px;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: .88rem;
    text-decoration: none;
    transition: all .2s;
    animation: fadeUp .5s .65s ease both;
  }

  .btn-back:hover {
    background: #E8D5A0;
    transform: translateY(-2px);
  }

  .sec-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 1.2rem;
    animation: fadeUp .5s .7s ease both;
  }

  .sec-links a {
    color: rgba(255,255,255,.35);
    font-size: .78rem;
    text-decoration: none;
    transition: color .2s;
  }

  .sec-links a:hover {
    color: rgba(255,255,255,.7);
  }

  @media(max-width:480px) {
    .card { padding: 2.5rem 1.5rem; }
    .card h1 { font-size: 1.6rem; }
  }
</style>
