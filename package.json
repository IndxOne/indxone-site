{
  "name": "indxone-site",
  "version": "1.0.0",
  "description": "Site web de INDXONE - Consultant SI & Architecte Digital",
  "private": true,
  "author": "Koffi NIAMKEY <contact@indxone.com>",
  "license": "MIT",
  "homepage": "https://indxone.com",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/indxone-group/indxone-site.git"
  },
  "bugs": {
    "url": "https://gitlab.com/indxone-group/indxone-site/-/issues"
  },
  "keywords": [
    "consultant",
    "SI",
    "AMOA",
    "freelance",
    "architecture",
    "digital",
    "PME",
    "transition",
    "automatisation",
    "no-code",
    "cloud"
  ],
  "scripts": {
    "dev": "npm run build:all && concurrently \"npm run server\" \"npm run watch:css\"",
    "build": "npm run build:css && npm run build:static",
    "build:css": "postcss css/style.css -o css/optimized.css --env production",
    "build:static": "node scripts/build.js",
    "build:all": "npm run build:css && npm run build:static",
    "watch:css": "postcss css/style.css -o css/optimized.css --watch",
    "server": "python3 -m http.server 8000 --directory dist",
    "serve": "npm run server",
    "lint": "npm run lint:css && npm run lint:html",
    "lint:dist": "npm run build:all && html-validate dist/index.html dist/*/index.html dist/en/*/index.html",
    "lint:full": "npm run lint && npm run lint:dist",
    "lint:css": "stylelint css/**/*.css",
    "lint:html": "npm run build:all && html-validate dist/index.html dist/*/index.html dist/en/*/index.html",
    "format": "prettier --write \"**/*.{html,css,js}\"",
    "format:check": "prettier --check \"**/*.{html,css,js}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "clean": "rm -rf node_modules dist temp .cache",
    "deploy": "npm run build:all && netlify deploy --prod --dir=dist",
    "deploy:staging": "npm run build:all && netlify deploy --dir=dist",
    "optimize-images": "node scripts/optimize-images.js"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@playwright/test": "^1.60.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cssnano": "^6.0.1",
    "html-minifier-terser": "^7.2.0",
    "html-validate": "^8.29.0",
    "jsdom": "^24.1.3",
    "lighthouse": "^10.4.0",
    "postcss": "^8.4.32",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.0.3",
    "sharp": "^0.34.5",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-prettier": "^4.0.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all",
    "not ie 11"
  ],
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 120,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "html"
        }
      }
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-prettier"
    ],
    "rules": {
      "color-no-invalid-hex": true,
      "declaration-block-no-duplicate-properties": true,
      "no-descending-specificity": null,
      "selector-pseudo-class-no-unknown": [
        true,
        {
          "ignorePseudoClasses": [
            "global",
            "local"
          ]
        }
      ]
    }
  }
}
